<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <androidx.cardview.widget.CardView
        android:id="@+id/cardProduct"
        app:cardElevation="25dp"
        app:cardCornerRadius="25dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="10dp"
        app:cardPreventCornerOverlap="true"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RelativeLayout
            android:id="@+id/relative"
            android:padding="2dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <ImageView
                android:id="@+id/productImage"
                android:layout_width="120dp"
                android:layout_height="150dp"
                android:src="@drawable/laptopp" />
            <TextView
                android:id="@+id/productName"
                android:text="DAC Notebook F1 D14 DN50 513 8-512"
                android:paddingLeft="10dp"
                android:textColor="@color/blue"
                android:textSize="16dp"
                android:textStyle="bold"
                android:layout_toRightOf="@id/productImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:id="@+id/productDesc"
                android:text="Chipset: Apple M4 Pro chip with 14‑core CPU and 20‑core GPU,RAM: 48GB, SSD: 512GB,Ukuran Layar: 16 inch Liquid Retina XDR display,Konektivitas: Wifi + Bluetooth,Unit Utama"
                android:paddingLeft="10dp"
                android:layout_below="@id/productName"
                android:textColor="@color/red"
                android:textSize="11dp"
                android:textStyle="bold"
                android:layout_marginTop="10dp"
                android:layout_toRightOf="@id/productImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <TextView
                android:id="@+id/productPrice"
                android:text="Rp. 17.820.000"
                android:paddingLeft="10dp"
                android:layout_below="@id/productDesc"
                android:textColor="@color/green"
                android:textSize="12dp"
                android:textStyle="bold"
                android:layout_marginTop="20dp"
                android:layout_toRightOf="@id/productImage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <ImageView
                android:id="@+id/star"
                android:src="@drawable/bintang"
                android:layout_below="@id/productPrice"
                android:layout_marginTop="10dp"
                android:layout_marginLeft="225dp"
                android:layout_width="15dp"
                android:layout_height="15dp"/>

            <TextView
                android:id="@+id/productPromo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/productPrice"
                android:layout_marginTop="10dp"
                android:layout_toRightOf="@id/star"
                android:paddingLeft="5dp"
                android:text="Promo Rp. 7.820.000"
                android:textColor="@color/red"
                android:textSize="12dp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDelete"
                android:layout_width="90dp"
                android:layout_height="40dp"
                android:layout_below="@+id/productDesc"
                android:layout_marginStart="280dp"
                android:text="delete"
                android:textColor="@color/red"
                android:textSize="12sp"

                />





        </RelativeLayout>
    </androidx.cardview.widget.CardView>
</RelativeLayout>